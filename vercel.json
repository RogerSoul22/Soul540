{
  "buildCommand": "vite build && npx esbuild api-src/index.ts --bundle --platform=node --format=cjs --outfile=api/index.js --external:mongoose --external:express --external:cors --external:dotenv --external:bcryptjs --external:serverless-http",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
